<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wallet.sysDict.mapper.SysDictMapper">
    <resultMap type="SysDict" id="SysDictResult">
		        <result property="id"    column="id"    />
		        <result property="num"    column="num"    />
		        <result property="pid"    column="pid"    />
		        <result property="name"    column="name"    />
		        <result property="tips"    column="tips"    />
		        <result property="code"    column="code"    />
		</resultMap>
	<resultMap id="BOSysDictResult" type="SysDictBO" extends="SysDictResult" />
	<sql id="Base_Column_List">
         id, num, pid, name, tips, code    </sql>
    <delete id="deleteSysDictByIds" parameterType="String">
        delete from w_sys_dict where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>