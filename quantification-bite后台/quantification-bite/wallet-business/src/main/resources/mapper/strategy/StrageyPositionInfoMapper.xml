<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wallet.strategy.mapper.StrageyPositionInfoMapper">
    <resultMap type="StrageyPositionInfo" id="StrageyPositionInfoResult">
		        <result property="id"    column="id"    />
		        <result property="apiAccountId"    column="api_account_id"    />
		        <result property="exchange"    column="exchange"    />
		        <result property="symbol"    column="symbol"    />
		        <result property="positionSide"    column="position_side"    />
		        <result property="quantity"    column="quantity"    />
		        <result property="openPrice"    column="open_price"    />
		        <result property="currenPrice"    column="curren_price"    />
		        <result property="liquidationPrice"    column="liquidation_price"    />
		        <result property="adl"    column="adl"    />
		        <result property="leverage"    column="leverage"    />
		        <result property="positionValue"    column="position_value"    />
		        <result property="cretaeTime"    column="cretae_time"    />
		</resultMap>
	<resultMap id="BOStrageyPositionInfoResult" type="StrageyPositionInfoBO" extends="StrageyPositionInfoResult" />
	<sql id="Base_Column_List">
         id, api_account_id, exchange, symbol, position_side, quantity, open_price, curren_price, liquidation_price, adl, leverage, position_value, cretae_time    </sql>
    <delete id="deleteStrageyPositionInfoByIds" parameterType="String">
        delete from b_stragey_position_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>