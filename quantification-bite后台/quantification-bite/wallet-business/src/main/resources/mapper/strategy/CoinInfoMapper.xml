<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wallet.strategy.mapper.CoinInfoMapper">
    <resultMap type="CoinInfo" id="CoinInfoResult">
		        <result property="id"    column="id"    />
		        <result property="name"    column="name"    />
		        <result property="isEnabled"    column="is_enabled"    />
		        <result property="isFixed"    column="is_fixed"    />
		        <result property="createDate"    column="create_date"    />
		        <result property="updateDate"    column="update_date"    />
		</resultMap>
	<resultMap id="BOCoinInfoResult" type="CoinInfoBO" extends="CoinInfoResult" />
	<sql id="Base_Column_List">
         id, name, is_enabled, is_fixed, create_date, update_date    </sql>
    <delete id="deleteCoinInfoByIds" parameterType="String">
        delete from t_coin_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

	<!--修改临时币种-->
	<update id="updateCoinFixed" parameterType="com.wallet.strategy.domain.CoinInfo">
		UPDATE 	t_coin_info SET name=#{name} WHERE is_fixed=#{isFixed}
	</update>
</mapper>