<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wallet.strategy.mapper.StrategyTypeMapper">
    <resultMap type="StrategyType" id="StrategyTypeResult">
		        <result property="id"    column="id"    />
		        <result property="type"    column="type"    />
		        <result property="name"    column="name"    />
		        <result property="isEnabled"    column="is_enabled"    />
		        <result property="createTime"    column="create_time"    />
		</resultMap>
	<resultMap id="BOStrategyTypeResult" type="StrategyTypeBO" extends="StrategyTypeResult" />
	<sql id="Base_Column_List">
         id, type, name, is_enabled, create_time    </sql>
    <delete id="deleteStrategyTypeByIds" parameterType="String">
        delete from t_strategy_type where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <select id="selectInfoByType" parameterType="java.lang.Integer" resultType="com.wallet.strategy.domain.StrategyType">
        select <include refid="Base_Column_List"></include>
        from t_strategy_type where type=#{type} LIMIT 0,1
    </select>
</mapper>