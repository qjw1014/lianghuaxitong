<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wallet.chain.mapper.ChainMapper">
    <resultMap type="Chain" id="ChainResult">
		        <result property="id"    column="id"    />
		        <result property="chainName"    column="chain_name"    />
		        <result property="chainNodeUrl"    column="chain_node_url"    />
		        <result property="synchronousHeight"    column="synchronous_height"    />
		        <result property="userName"    column="user_name"    />
		        <result property="status"    column="status"    />
		        <result property="password"    column="password"    />
		        <result property="blockTime"    column="block_time"    />
		        <result property="createTime"    column="create_time"    />
		        <result property="chainIconUrlAbs"    column="chain_icon_url_abs"    />
		        <result property="chainIconUrlAbsRelative"    column="chain_icon_url_abs_relative"    />
		        <result property="mainCoinName"    column="main_coin_name"    />
		        <result property="browserLinks"    column="browser_links"    />
		        
		</resultMap>
	<resultMap id="BOChainResult" type="ChainBO" extends="ChainResult" />
	<sql id="Base_Column_List">
         id, chain_name, chain_node_url, synchronous_height, user_name, status, password, block_time, create_time, chain_icon_url_abs, chain_icon_url_abs_relative, main_coin_name,browser_links    </sql>
    <delete id="deleteChainByIds" parameterType="String">
        delete from w_chain where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>